# Postgres connection string (Neon → Project → Connection Details).
# For the deployed app (serverless), use the pooled connection string
# (host contains "-pooler", e.g. ep-xxx-pooler.us-east-2.aws.neon.tech).
# For running `pnpm --filter @workspace/db run push` locally, use the
# unpooled/direct connection string instead — PgBouncer transaction mode
# doesn't support the session-level features drizzle-kit needs.
DATABASE_URL=

# Random secret used to sign session cookies. Generate with:
#   openssl rand -base64 32
SESSION_SECRET=
